---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { coffeeSize } from "@/lib/coffeeSize";

const posts = (await getCollection("noticias"))
  .map((entry) => ({
    slug: entry.slug,
    title: entry.data.title,
    date: entry.data.date,
    resumen: entry.data.resumen ?? "",
    size: coffeeSize(entry.body),
  }))
  .sort((a, b) => (a.date < b.date ? 1 : -1));
---
<Layout
  title="Noticias"
  description="Noticias y análisis del SSC Napoli en español."
>
  <main class="container">
    <h1 class="page-title">Noticias</h1>
    {posts.length === 0 ? (
      <p class="empty">Próximamente.</p>
    ) : (
      <ul class="post-list">
        {posts.map((p) => (
          <li>
            <a href={`/noticias/${p.slug}`}>
              <span class="post-date">
                {p.date}
                <span class="size-pill" title={`${p.size.minutes} min lectura`}>
                  <span class={`size-dot size-${p.size.label.toLowerCase()}`} aria-hidden="true"></span>
                  {p.size.label}
                </span>
              </span>
              <span class="post-title">{p.title}</span>
              {p.resumen && <span class="post-sum">{p.resumen}</span>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>
