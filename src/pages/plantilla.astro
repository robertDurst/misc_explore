---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { SQUAD_GROUPS } from "@/content/config";
import { ageFromDob, transferLine } from "@/lib/squad";

const all = await getCollection("jugadores");
// Stable order: group → shirt number ascending → alphabetical (es).
const squad = all
  .map((entry) => ({ slug: entry.slug, ...entry.data }))
  .sort((a, b) => {
    const ga = SQUAD_GROUPS.indexOf(a.position);
    const gb = SQUAD_GROUPS.indexOf(b.position);
    if (ga !== gb) return ga - gb;
    if (a.shirtNumber !== undefined && b.shirtNumber !== undefined) {
      return a.shirtNumber - b.shirtNumber;
    }
    if (a.shirtNumber !== undefined) return -1;
    if (b.shirtNumber !== undefined) return 1;
    return a.name.localeCompare(b.name, "es");
  });
---
<Layout
  title="Plantilla"
  description="La plantilla del Napoli para la temporada 2025-26 con datos de contrato, fichaje y dorsales."
>
  <main class="container">
    <h1 class="page-title">Plantilla</h1>
    <p class="page-sub">Temporada 2025-26</p>

    {SQUAD_GROUPS.map((group) => {
      const players = squad.filter((p) => p.position === group);
      if (players.length === 0) return null;
      return (
        <section class="squad-section">
          <h2 class="section-title">{group}</h2>
          <ul class="squad-list">
            {players.map((p) => {
              const age = ageFromDob(p.dob);
              const transfer = transferLine(p);
              return (
                <li class="player-card">
                  {p.shirtNumber !== undefined && (
                    <span class="player-number" aria-label={`Dorsal ${p.shirtNumber}`}>
                      {p.shirtNumber}
                    </span>
                  )}
                  <div class="player-name">{p.name}</div>
                  <div class="player-meta">
                    <span class="role">{p.role}</span>
                    <span class="dot">·</span>
                    <span class="flag" aria-hidden="true">{p.flag}</span>
                    <span class="nationality">{p.nationality}</span>
                    <span class="dot">·</span>
                    <span class="age">{age} años</span>
                  </div>
                  {transfer && <div class="player-transfer">{transfer}</div>}
                  {p.loanTo && <div class="player-loan">→ Cedido a {p.loanTo}</div>}
                </li>
              );
            })}
          </ul>
        </section>
      );
    })}

    <p class="plantilla-note">
      Plantilla aproximada · {squad.length} jugadores · datos curados en src/content/jugadores/*.md.
    </p>
  </main>
</Layout>
